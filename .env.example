# Copy to .env and fill in. .env is gitignored.

# Sepolia JSON-RPC endpoint (Alchemy, Infura, or any Sepolia node).
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key

# Chainlink VRF v2.5 subscription id created at https://vrf.chain.link (Sepolia).
# This is a large 256-bit number for v2.5 — paste it as-is.
VRF_SUBSCRIPTION_ID=0

# Etherscan API key, used by `forge script --verify`.
ETHERSCAN_API_KEY=your-etherscan-api-key
